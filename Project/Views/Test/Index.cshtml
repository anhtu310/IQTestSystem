@model IEnumerable<Project.Models.Test>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TestName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TimeLimit)
            </th>

            <th>
                Status
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.TestName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TimeLimit)
                </td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="btn btn-success">Active</span>
                    }
                    else
                    {
                        <span class="btn btn-danger">Inactive</span>
                    }
                </td>
                <td>
                    @(item.Category != null ? item.Category.CategoryName.ToString() : "Không có danh mục")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.TestId">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.TestId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>